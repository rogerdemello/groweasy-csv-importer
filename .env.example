# ---------------------------------------------------------------------------
# GrowEasy CSV Importer — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# --- LLM provider (NVIDIA NIM, OpenAI-compatible) ---------------------------
# Get a free key at https://build.nvidia.com
# If NVIDIA_API_KEY is omitted, the app automatically runs in MOCK mode using a
# deterministic heuristic mapper (no network) so it always works out of the box.
NVIDIA_API_KEY=

# Optional overrides (sensible defaults are baked in):
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.1-8b-instruct
# LLM_TEMPERATURE=0

# --- Extraction tuning -----------------------------------------------------
# BATCH_SIZE=8            # rows sent to the model per request
# MAX_RETRIES=3          # retry attempts per batch before heuristic fallback
# REQUEST_TIMEOUT=60     # per-request timeout in seconds

# --- Force mock (heuristic) mode even when a key is present -----------------
# USE_MOCK=0

# --- Server ----------------------------------------------------------------
# PORT=3000
