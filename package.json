{
  "name": "groweasy-csv-importer",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered CSV importer that maps any CSV into the GrowEasy CRM schema.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --ignore \"src/**\" --ignore \".next/**\" server/main.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.11.2",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "next-themes": "^0.4.4",
    "openai": "^4.77.3",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.12",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
